APP_ENV=dev
DEBUG=true
API_PREFIX=/api/v1
ALLOWED_ORIGINS=*

# Demo helper
# Auto-seed database from CSVs on startup if DB is empty
AUTO_SEED_DEMO=true

# Database
# Default (no setup): SQLite
DATABASE_URL=sqlite+aiosqlite:///./aml.db
# Or use Postgres (requires a running Postgres server):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aml

# Redis
# Docker Compose (recommended): the hostname is the service name
REDIS_URL=redis://redis:6379/0
# Local (no Docker): use localhost instead
# REDIS_URL=redis://localhost:6379/0

# Production tip:
# - Set DEBUG=false
# - Set ALLOWED_ORIGINS to your frontend origin(s)

# Data + ML
DATA_DIR=src/aml_monitoring_system/data
ML_MODEL_PATH=src/app/ml/models
