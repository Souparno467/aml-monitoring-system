__pycache__/
.venv/
*.pyc

# Env files (never commit secrets)
.env
.env.*
!.env.example

# Local demo DB
aml.db
*.sqlite

# Large datasets / models (do not commit)
src/aml_monitoring_system/data/*.csv
# Keep the default trained model in-repo for deployments that run with DEBUG=false.
# Ignore other models/artifacts by default.
src/app/ml/models/*
!src/app/ml/models/.gitkeep
!src/app/ml/models/xgb_aml_v1.joblib
*.pkl

# Frontend
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local
frontend/.env.*.local
